# Environment Configuration
NODE_ENV=development
PORT=3000

# Database — connection pool params (tune for production):
#   connection_limit=20  (max pool connections, Prisma default is num_cpus * 2 + 1)
#   pool_timeout=10      (seconds to wait for available connection)
#   connect_timeout=5    (seconds to wait for new connection)
DATABASE_URL="postgresql://user:password@localhost:5432/ecommerce_cod?connection_limit=20&pool_timeout=10&connect_timeout=5"

# Security - JWT Configuration
# IMPORTANT: Generate strong secrets (minimum 32 characters)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-here

# Security - Webhook Configuration
WEBHOOK_SECRET=your-super-secret-webhook-key-min-32-chars-here

# Bootstrap Admin Configuration
# Used for first-time deployment to create initial admin user
# Only runs if database is empty (no users exist)
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=your-strong-password-here-min-8-chars
BOOTSTRAP_ADMIN_FIRST_NAME=Admin
BOOTSTRAP_ADMIN_LAST_NAME=User
BOOTSTRAP_ADMIN_PHONE=+1234567890

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
# Platform admin subdomain URL (for CORS)
PLATFORM_URL=https://platform.codadminpro.com

# Optional: File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Email Configuration (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=COD Admin <no-reply@codadminpro.com>

# Optional: SMS Configuration (for notifications)
# TWILIO_ACCOUNT_SID=your-twilio-sid
# TWILIO_AUTH_TOKEN=your-twilio-token
# TWILIO_PHONE_NUMBER=+1234567890

# Provider credential encryption (AES-256-GCM)
# Encrypts WhatsApp/SMS/Email API tokens at rest in the database.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# PROVIDER_ENCRYPTION_KEY=

# Optional: Payment Gateway
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: WhatsApp Business API OAuth (Facebook Login for Business)
# Set these to enable the "Connect with Meta" OAuth flow in WhatsApp settings.
# If absent, only manual token entry is available.
# META_APP_ID=<your-meta-app-id>
# META_APP_SECRET=<your-meta-app-secret>
# BACKEND_URL=http://localhost:3000

# Optional: Monitoring & Logging
# SENTRY_DSN=https://...@sentry.io/...
# LOG_LEVEL=info
